# Opcion 1 para modelos geo
import numpy as np
import pandas as pd
##Trabajos para NoEmp para bagging se podria dejar tal cual para modelos geometric si se debe standarizar
# 1. Definimos la función de categorización (Binning)
# Basada en tus cuartiles: Micro (0-5), Pequeña (6-15), Mediana/Grande (16+)
def categorizar_empresa(n):
    if n <= 5: 
        return 1 # Categoría Micro
    elif n <= 15: 
        return 2 # Categoría Pequeña
    else: 
        return 3 # Categoría Mediana/Grande

# 2. Aplicamos la categorización
df['Empresa_Size_Ordinal'] = df['NoEmp'].apply(categorizar_empresa)

# 3. Aplicamos la Transformación Logarítmica a la original
# log1p maneja el valor 0 de empleados correctamente: log(0 + 1)
df['NoEmp_Log'] = np.log1p(df['NoEmp'])

# Verificamos cómo quedaron las nuevas columnas
print(df[['NoEmp', 'Empresa_Size_Ordinal', 'NoEmp_Log']].head(10))

#opcion 2 para modelos geo
# 1. Transformación logarítmica
df['NoEmp_Log'] = np.log1p(df['NoEmp'])

# 2. Definir features
features = [
    'NoEmp_Log','NewExist','CreateJob','RetainedJob',
    'DisbursementGross','BalanceGross','UrbanRural',
    'RevLineCr','LowDoc','City','Bank','IsLocalBank'
]

X = df[features]
y = df['Accept']

# 3. Pipeline con escalado + KNN
from sklearn.pipeline import Pipeline
from sklearn.preprocessing import StandardScaler
from sklearn.neighbors import KNeighborsClassifier

pipeline_knn = Pipeline(steps=[
    ('scaler', StandardScaler()),
    ('knn', KNeighborsClassifier())
])

# 4. Entrenar
pipeline_knn.fit(X, y)
